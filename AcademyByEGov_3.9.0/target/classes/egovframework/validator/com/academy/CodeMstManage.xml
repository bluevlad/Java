<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE form-validation PUBLIC 
    "-//Apache Software Foundation//DTD Commons Validator Rules Configuration 1.1//EN" 
    "http://jakarta.apache.org/commons/dtds/validator_1_1.dtd">

<form-validation>

    <formset>
        <form name="CodeMstVO">
			<field property="codeId" depends="required, maxlength">
        		<arg0 key="comSymCcmCca.CodeVO.codeId" resource="true"/><!-- 코드ID -->
        		<arg1 key="6" resource="true"/>
				<var>
				<var-name>maxlength</var-name>
				<var-value>6</var-value>
				</var>
			</field> 
			<field property="codeNm" depends="required, maxlength">
        		<arg0 key="comSymCcmCca.CodeVO.codeNm" resource="true"/><!-- 코드ID명 -->
        		<arg1 key="60" resource="true"/>
				<var>
				<var-name>maxlength</var-name>
				<var-value>60</var-value>
				</var>
			</field> 
			<field property="codeDc" depends="required, maxlength">
        		<arg0 key="comSymCcmCca.CodeVO.codeDc" resource="true"/><!-- 코드ID설명 -->
        		<arg1 key="200" resource="true"/>
				<var>
				<var-name>maxlength</var-name>
				<var-value>200</var-value>
				</var>
			</field> 
			<field property="useAt" depends="required">
        		<arg0 key="comSymCcmCca.CodeVO.useAt" resource="true"/><!-- 사용여부 -->
			</field> 
		</form>
    </formset>

</form-validation>
