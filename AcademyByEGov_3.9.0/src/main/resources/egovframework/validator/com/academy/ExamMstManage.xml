<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE form-validation PUBLIC 
    "-//Apache Software Foundation//DTD Commons Validator Rules Configuration 1.1//EN" 
    "http://jakarta.apache.org/commons/dtds/validator_1_1.dtd">

<form-validation>

    <formset>
        <form name="ExamVO">
			<field property="examCd" depends="required">
        		<arg0 key="exam.examManageList.ExamCd" resource="true"/><!-- 시험코드 -->
			</field> 
			<field property="examNm" depends="required, maxlength">
        		<arg0 key="exam.examManageList.ExamNm" resource="true"/><!-- 시험명 -->
        		<arg1 key="60" resource="true"/>
				<var>
					<var-name>maxlength</var-name>
					<var-value>60</var-value>
				</var>
			</field> 
			<field property="isUse" depends="required">
        		<arg0 key="exam.examManageList.isUse" resource="true"/><!-- 사용여부 -->
			</field> 
		</form>
    </formset>

</form-validation>
